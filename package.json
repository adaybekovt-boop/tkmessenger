{
  "name": "orbits-p2p",
  "version": "5.1.0",
  "description": "Decentralized P2P Messenger",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron electron.mjs",
    "electron-dev": "NODE_ENV=development electron electron.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "peerjs": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.orbits.p2p",
    "productName": "Orbits P2P",
    "files": ["dist/**/*", "electron.mjs", "preload.cjs"],
    "directories": { "output": "release" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
