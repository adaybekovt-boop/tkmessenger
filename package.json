{
  "name": "orbits-p2p",
  "version": "5.1.0",
  "description": "Decentralized P2P Messenger",
  "type": "module",
  "main": "electron.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron electron.mjs",
    "electron-dev": "NODE_ENV=development electron electron.mjs",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run build && npx cap sync android"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "peerjs": "^1.5.4",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "terser": "^5.36.0",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.orbits.p2p",
    "productName": "Orbits P2P",
    "files": [
      "dist/**/*",
      "electron.mjs",
      "preload.cjs"
    ],
    "directories": { "output": "release" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "dist/assets/icon.ico",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "dist/assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "dist/assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
