# App Config
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/orbits_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication (JWT)
JWT_ACCESS_SECRET="your_access_secret_here_change_it"
JWT_REFRESH_SECRET="your_refresh_secret_here_change_it"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Storage (Firebase/Cloudinary)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
FIREBASE_CONFIG='{"apiKey": "...", "authDomain": "...", "projectId": "...", "storageBucket": "...", "messagingSenderId": "...", "appId": "..."}'
